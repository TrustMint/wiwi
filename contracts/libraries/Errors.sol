pragma solidity ^0.8.20;

/**
 * @title Errors
 * @author DeMarket Protocol Team
 * @notice Библиотека кастомных ошибок (Custom Errors) для всей экосистемы.
 * @dev Используется для экономии газа (дешевле, чем require со строками) и удобства отладки.
 */
library Errors {
    
    // =============================================================
    //                           COMMON
    // =============================================================
    
    /// @notice Передан нулевой адрес (address(0)) там, где это запрещено
    error InvalidAddress();
    
    /// @notice Передана нулевая сумма или некорректное значение
    error InvalidAmount();
    
    /// @notice У вызывающего нет прав на выполнение действия
    error NotAuthorized();

    // =============================================================
    //                     TOKEN & SOULBOUND
    // =============================================================

    /// @notice Попытка передать Soulbound токен (запрещено логикой)
    error SoulboundTransferFailed();

    // =============================================================
    //                        MARKETPLACE
    // =============================================================

    /// @notice Токен не поддерживается платформой для оплаты
    error TokenNotAllowed();
    
    /// @notice Цена не может быть нулевой
    error InvalidPrice();
    
    /// @notice Количество товара не может быть нулевым
    error InvalidQuantity();
    
    /// @notice Действие разрешено только продавцу листинга
    error NotSeller();
    
    /// @notice Листинг не активен (продан, отменен или еще не создан)
    error ListingNotActive();
    
    /// @notice Недостаточно товара на складе для покупки
    error InsufficientStock();
    
    /// @notice Продавец не может купить свой собственный товар
    error CannotBuyOwnListing();
    
    /// @notice Действие разрешено только покупателю
    error NotBuyer();
    
    /// @notice Статус сделки (Escrow) не позволяет выполнить действие
    error InvalidEscrowStatus();
    
    /// @notice Предлагаемая комиссия превышает максимально допустимую (защита DAO)
    error FeeTooHigh();

    // =============================================================
    //                          STAKING
    // =============================================================

    /// @notice Попытка вывести заблокированные (в спорах) средства
    error FundsLocked();
    
    /// @notice Недостаточно стейка для действия (например, блокировки залога)
    error InsufficientStake();

    // =============================================================
    //                        ARBITRATION
    // =============================================================

    /// @notice Вызывающий не является назначенным арбитром или контрактом арбитража
    error NotArbitrator();
    
    /// @notice Неверный статус спора для данного действия
    error InvalidDisputeStatus();
    
    /// @notice Время на голосование или набор судей истекло
    error DisputeExpired();
    
    /// @notice Пользователь не соответствует требованиям для становления судьей (мало стейка)
    error NotQualifiedArbitrator();
    
    /// @notice Пользователь уже является присяжным в этом споре
    error AlreadyJuror();
    
    /// @notice Арбитр уже проголосовал
    error AlreadyVoted();
    
    /// @notice Нельзя завершить спор, пока голосование не окончено (и время не вышло)
    error VotingNotFinished();
    
    /// @notice Некорректный размер жюри (должно быть нечетным)
    error InvalidJurySize();

    // =============================================================
    //                        REPUTATION
    // =============================================================

    /// @notice Нельзя оставить отзыв, так как сделка не была завершена успешно
    error TradeNotCompleted();
    
    /// @notice Время для оставления отзыва истекло
    error ReviewWindowClosed();
    
    /// @notice Отзыв по этой сделке уже был оставлен
    error ReviewAlreadySubmitted();
    
    /// @notice Рейтинг должен быть в диапазоне 1-100
    error InvalidRating();
}